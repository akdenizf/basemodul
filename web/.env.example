# AGENTEQ KMU Assistants — Environment Template
# Kopiere diese Datei zu .env.local und fuelle EIGENE Keys ein.
# NIEMALS echte Callfolio-Production-Keys hier verwenden.
# Fuer den Lean-MVP (nur Landing + Demo) werden KEINE dieser Keys benoetigt.

# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_UPLOAD_BASE_URL=http://localhost:3000

# --- Supabase (Backend, geparkt — nur fuer spaetere Pilot-Verdrahtung) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SECRET_KEY=

# --- Vapi (Voice-Assistent, geparkt) ---
NEXT_PUBLIC_VAPI_PUBLIC_KEY=
VAPI_WEBHOOK_SECRET=

# --- Resend (E-Mail-Versand, geparkt — im MVP deaktiviert) ---
RESEND_API_KEY=
RESEND_FROM=
TICKETS_EMAIL_TO=

# --- Twilio (SMS/WhatsApp, geparkt) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_PHONE_NUMBER=
TWILIO_SENDER_ID=

# --- Admin / Mapping (geparkt) ---
ADMIN_EMAIL=
ADMIN_PASSWORD=
TENANT_MAPPING=
